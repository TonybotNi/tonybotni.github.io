---
import { NAV_LINKS, PAGES } from "../../config";

const currentPath = Astro.url.pathname;
---

<nav class="navbar">
    <button
        type="button"
        class="nav-arrow nav-arrow-left"
        aria-label="Scroll navigation left"
        tabindex="-1"
    >
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <path
                d="M15 6l-6 6 6 6"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
        </svg>
    </button>
    <ul class="nav-links">
        {
            NAV_LINKS.filter((link) => {
                const isHome = link.href === "/";
                const pageKey = isHome
                    ? "home"
                    : link.href.split("/").filter(Boolean)[0];
                const pageConfig = (PAGES as any)[pageKey];
                return link.isActive !== false && pageConfig?.active !== false;
            }).map((link) => (
                <li>
                    <a
                        href={link.href}
                        class={`nav-link ${
                            currentPath === link.href ||
                            (link.href !== "/" &&
                                currentPath.startsWith(link.href))
                                ? "active"
                                : "inactive"
                        }`}
                    >
                        {link.label}
                        <span class="nav-link-line" />
                    </a>
                </li>
            ))
        }
    </ul>
    <button
        type="button"
        class="nav-arrow nav-arrow-right"
        aria-label="Scroll navigation right"
        tabindex="-1"
    >
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <path
                d="M9 6l6 6-6 6"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
        </svg>
    </button>
</nav>

<script>
    function initNavScroll() {
        document.querySelectorAll<HTMLElement>(".navbar").forEach((navbar) => {
            const list = navbar.querySelector<HTMLElement>(".nav-links");
            const leftBtn = navbar.querySelector<HTMLElement>(".nav-arrow-left");
            const rightBtn =
                navbar.querySelector<HTMLElement>(".nav-arrow-right");
            if (!list || !leftBtn || !rightBtn) return;
            if ((navbar as any)._navScrollInit) return;
            (navbar as any)._navScrollInit = true;

            const update = () => {
                const max = list.scrollWidth - list.clientWidth;
                const x = list.scrollLeft;
                navbar.classList.toggle("can-scroll-left", x > 1);
                navbar.classList.toggle("can-scroll-right", x < max - 1);
            };

            const scrollByStep = (dir: number) => {
                list.scrollBy({
                    left: dir * Math.max(list.clientWidth * 0.7, 120),
                    behavior: "smooth",
                });
            };

            leftBtn.addEventListener("click", () => scrollByStep(-1));
            rightBtn.addEventListener("click", () => scrollByStep(1));
            list.addEventListener("scroll", update, { passive: true });
            window.addEventListener("resize", update);
            update();
            // Re-check after fonts/layout settle.
            setTimeout(update, 200);
        });
    }

    initNavScroll();
    document.addEventListener("astro:page-load", initNavScroll);
    document.addEventListener("astro:after-swap", () => {
        document
            .querySelectorAll<HTMLElement>(".navbar")
            .forEach((n) => ((n as any)._navScrollInit = false));
        initNavScroll();
    });
</script>
