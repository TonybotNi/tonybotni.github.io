---
import BaseLayout from "../layouts/BaseLayout.astro";
import { toAssetUrl } from "../utils/assets";
---

<BaseLayout title="Internship" description="Internship experience.">
    <header class="page-header">
        <h1 class="page-title">Internship</h1>
        <p class="page-subtitle">Industry experience in foundation model post-training and agent systems.</p>
    </header>

    <section class="internship-list">
        <article class="internship-card">
            <div class="internship-logo-box">
                <img src={toAssetUrl("/images/StepFun-logo.png")} alt="StepFun logo" class="internship-logo stepfun-logo" />
            </div>
            <div class="internship-content">
                <h2>StepFun</h2>
                <p class="internship-meta">Foundation Model Team · Multimodal Working Agent Training Group</p>
                <p><strong>Foundation Model Post-training Intern</strong> · Jun. 2026 - Present</p>
            </div>
        </article>

        <article class="internship-card">
            <div class="internship-logo-box">
                <img src={toAssetUrl("/images/hunyuan.png")} alt="Tencent Hunyuan logo" class="internship-logo" />
            </div>
            <div class="internship-content">
                <h2>Tencent</h2>
                <p class="internship-meta">TEG · Hunyuan LLM Division</p>
                <p><strong>Frontier Intern</strong> · Oct. 2025 - Apr. 2026</p>
            </div>
        </article>

        <article class="internship-card">
            <div class="internship-logo-box">
                <img src={toAssetUrl("/images/huawei.png")} alt="Huawei logo" class="internship-logo huawei-logo" />
            </div>
            <div class="internship-content">
                <h2>Huawei</h2>
                <p class="internship-meta">2012 Labs · Foundation Model Dept · Multimodal Document Understanding and Grounded Reasoning</p>
                <p><strong>Algorithm Intern</strong> · Mar. 2025 - Sep. 2025</p>
            </div>
        </article>
    </section>
</BaseLayout>
