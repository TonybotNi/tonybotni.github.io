---
import { getCollection } from "astro:content";
import BaseDetail from "../../layouts/BaseDetail.astro";
import ShareButtons from "../../components/ui/ShareButtons.astro";
import { getReadingTime } from "../../utils/readingTime";
import {
    getAlternatePostId,
    isChinesePostId,
    sortPostsByDate,
} from "../../utils/posts";
import { PAGES, SITE } from "../../config";

if (PAGES.blog.isActive === false) {
    return Astro.redirect("/404");
}

export async function getStaticPaths() {
    if (PAGES.blog.isActive === false) return [];
    const allPosts = await getCollection("posts");
    const englishPosts = sortPostsByDate(allPosts.filter((p) => !isChinesePostId(p.id)));
    const chinesePosts = sortPostsByDate(allPosts.filter((p) => isChinesePostId(p.id)));

    return allPosts.map((post) => {
        const sameLangPosts = isChinesePostId(post.id) ? chinesePosts : englishPosts;
        const index = sameLangPosts.findIndex((p) => p.id === post.id);

        return {
            params: { id: post.id },
            props: {
                post,
                prevPost: index > 0 ? sameLangPosts[index - 1] : null,
                nextPost: index < sameLangPosts.length - 1 ? sameLangPosts[index + 1] : null,
            },
        };
    });
}

const { post, prevPost, nextPost } = Astro.props;
const allPosts = await getCollection("posts");
const postIds = new Set(allPosts.map((p) => p.id));
const isZh = isChinesePostId(post.id);
const alternateId = getAlternatePostId(post.id);
const hasAlternate = postIds.has(alternateId);
const switchHref = `/posts/${alternateId}`;
const switchLabel = isZh ? "English" : "中文";
const readingTime = `${getReadingTime(post.body || "")} min read`;
const postUrl = new URL(`/posts/${post.id}`, SITE.website).href;
---

<BaseDetail collection="posts" id={post.id} readingTime={readingTime}>
    {
        hasAlternate && (
            <a slot="actions" href={switchHref} class="lang-link">
                {switchLabel}
            </a>
        )
    }
    <nav
        slot="footer"
        class="post-navigation container-narrow flex justify-between mt-24 pt-12 gap-8"
    >
        {
            prevPost && (
                <a
                    href={`/posts/${prevPost.id}`}
                    class="nav-prev flex flex-col group max-w-[45%] no-underline"
                >
                    <span class="nav-label text-[0.8rem] uppercase tracking-wider opacity-75 font-bold mb-2">
                        Previous Post
                    </span>
                    <span class="nav-title text-lg font-semibold text-foreground group-hover:text-accent transition-colors duration-200 leading-snug">
                        {prevPost.data.title}
                    </span>
                </a>
            )
        }
        <div class="nav-spacer flex-1"></div>
        {
            nextPost && (
                <a
                    href={`/posts/${nextPost.id}`}
                    class="nav-next flex flex-col items-end text-right group max-w-[45%] no-underline"
                >
                    <span class="nav-label text-[0.8rem] uppercase tracking-wider opacity-75 font-bold mb-2">
                        Next Post
                    </span>
                    <span class="nav-title text-lg font-semibold text-foreground group-hover:text-accent transition-colors duration-200 leading-snug">
                        {nextPost.data.title}
                    </span>
                </a>
            )
        }
    </nav>
    <div slot="share" class="container-narrow">
        <ShareButtons title={post.data.title} url={postUrl} description={post.data.description} />
    </div>
</BaseDetail>
