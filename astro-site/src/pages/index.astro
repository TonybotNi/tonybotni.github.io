---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Timeline from "../components/ui/Timeline.astro";
import { PAGES } from "../config";

// Load bio content
const bioEntry = await getEntry("bio", "bio");
const { Content: BioContent } = bioEntry
	? await render(bioEntry)
	: { Content: null };

const internship = bioEntry?.data.internship ?? [];
---

<BaseLayout title={PAGES.home.title}>
	<div class="container-narrow">
		{
			(PAGES.home.title || PAGES.home.subtitle) && (
				<header class="page-header">
					{PAGES.home.title && (
						<h1 class="page-title">👋 {PAGES.home.title}</h1>
					)}
					{PAGES.home.subtitle && (
						<p class="page-subtitle">{PAGES.home.subtitle}</p>
					)}
				</header>
			)
		}
		<div class="prose">
			{BioContent ? <BioContent /> : <p>Loading bio...</p>}
		</div>
		{internship.length > 0 && (
			<section class="section">
				<h2 id="internship" class="section-title border-b border-border pb-2">💼 Internship</h2>
				<Timeline compact items={internship.map(item => ({
					title: item.company,
					subtitle: item.role,
					period: item.period,
					description: item.description,
				}))} />
			</section>
		)}
	</div>
</BaseLayout>
